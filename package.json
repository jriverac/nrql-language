{
  "name": "nrql-formatter",
  "displayName": "NRQL Formatter",
  "description": "A formatter for New Relic Query Language (NRQL)",
  "version": "0.1.0",
  "publisher": "local",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Formatters"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/yourusername/nrql-formatter"
  },
  "activationEvents": [
    "onLanguage:nrql"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "nrql",
        "aliases": [
          "NRQL",
          "nrql"
        ],
        "extensions": [
          ".nrql"
        ]
      }
    ],
    "documentFormattingProvider": [
      {
        "language": "nrql"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "build": "vite build",
    "dev": "vite build --watch",
    "test": "jest",
    "test:watch": "jest --watch",
    "package": "vsce package",
    "lint": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^20.11.19",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^2.23.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.2",
    "typescript": "^5.3.3",
    "vite": "^5.1.3",
    "vite-plugin-node-polyfills": "^0.21.0"
  }
}
